# JWT signing secret. MUST match the control-plane secret so JWTs issued there
# verify here. HS256 for v1; rotate to RS256 + JWKS together with control-plane
# for production.
JWT_SECRET=dev-only-replace-in-production-this-must-be-at-least-32-chars

# Server
PORT=4001
HOST=0.0.0.0
LOG_LEVEL=info

# Per-connection backpressure threshold (bytes). When socket.bufferedAmount
# exceeds this, new messages to that connection are dropped (oldest-style:
# we drop the new write rather than letting the buffer grow unboundedly,
# since WebSocket frames already in the kernel buffer cannot be unqueued).
MAX_BUFFERED_BYTES=10485760
